# ═══════════════════════════════════════════════════
# APEX TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ═══════════════════════════════════════════════════
# PAPER/LIVE MODE TOGGLE
# ═══════════════════════════════════════════════════
IS_PAPER=true
PAPER_BALANCE=10000.0

# ═══════════════════════════════════════════════════
# POLYMARKET CREDENTIALS
# ═══════════════════════════════════════════════════
# Get from: https://docs.polymarket.com
POLYMARKET_PK=your_private_key_here
POLYMARKET_PROXY_ADDRESS=your_proxy_address_here

# ═══════════════════════════════════════════════════
# BINANCE API (for price data)
# ═══════════════════════════════════════════════════
# Create at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ═══════════════════════════════════════════════════
# NEWS & SENTIMENT
# ═══════════════════════════════════════════════════
# Benzinga: https://www.benzinga.com/apis
BENZINGA_API_KEY=

# ═══════════════════════════════════════════════════
# ON-CHAIN DATA
# ═══════════════════════════════════════════════════
# CryptoQuant: https://cryptoquant.com/api-docs
CRYPTOQUANT_API_KEY=

# ═══════════════════════════════════════════════════
# SOCIAL SIGNALS
# ═══════════════════════════════════════════════════
# Neynar (Farcaster): https://docs.neynar.com
NEYNAR_API_KEY=

# ═══════════════════════════════════════════════════
# INFRASTRUCTURE
# ═══════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://apex_user:your_password@localhost:5432/apex

# ═══════════════════════════════════════════════════
# RISK PARAMETERS
# ═══════════════════════════════════════════════════
MAX_POSITION_PCT=0.03            # 3% max per trade
MIN_EDGE_THRESHOLD=0.12          # 12% minimum edge to trade
KELLY_FRACTION=0.25              # Quarter-Kelly for safety
DRAWDOWN_HALT_PCT=0.18           # Stop trading at 18% drawdown

# ═══════════════════════════════════════════════════
# ADVANCED SETTINGS (optional)
# ═══════════════════════════════════════════════════
LOG_LEVEL=INFO
MAX_OPEN_POSITIONS=5
MIN_MARKET_LIQUIDITY=50000       # $50K minimum daily volume
